{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/lib",
        "declarationMap": true,
        "target": "ES2022",
        "declaration": true,
        "inlineSources": true,
        "types": [],
        "skipLibCheck": true,
        "lib": [
            "dom",
            "ES2022"
        ]
    },
    "angularCompilerOptions": {
        "skipTemplateCodegen": true,
        "strictMetadataEmit": true,
        "enableResourceInlining": true,
        "strictInjectionParameters": true,
        "strictTemplates": true
    },
    "exclude": [
        "src/test.ts",
        "**/*.spec.ts"
    ]
}
