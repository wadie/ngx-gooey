{
  "name": "ngx-gooey",
  "version": "21.0.1",
  "scripts": {
    "build": "npx ng-packagr -p ng-package.json",
    "build:docs": "npm run build && cd docs && npm install && npm run build",
    "build:release": "npx ng-packagr -p ng-package.json",
    "build:watch": "npx ng-packagr -p ng-package.json -w",
    "ng": "ng",
    "release": "npm run build:release && npm publish dist/",
    "release:beta": "npm run build:release && npm publish dist/ --tag beta",
    "start": "ng serve"
  },
  "repository": {
    "type": "git",
    "url": "https://www.github.com/wadie/ngx-gooey"
  },
  "author": {
    "name": "Wadie",
    "email": "1206307+wadie@users.noreply.github.com"
  },
  "keywords": [
    "angular",
    "angular component",
    "gooey"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://www.github.com/wadie/ngx-gooey/issues"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.1.3",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.2",
    "zone.js": "~0.15.0"
  }
}
